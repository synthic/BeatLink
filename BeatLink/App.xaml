<?xml version="1.0" encoding="utf-8"?>
<Application
  x:Class="BeatLink.App"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:BeatLink">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <!-- Other merged dictionaries here -->
      </ResourceDictionary.MergedDictionaries>

      <Color x:Key="RunnerRed">#CE0808</Color>

      <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="White" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
      </Style>

      <!-- Override specific default brush colors -->
      <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="White" />
      <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource RunnerRed}" />
      <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="White" />
      <SolidColorBrush x:Key="ButtonForegroundPressed" Color="{StaticResource RunnerRed}" />
      <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="White" />
    </ResourceDictionary>
  </Application.Resources>
</Application>
